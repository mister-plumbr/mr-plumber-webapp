// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  bookings  Booking[]
  reviews   Review[]

  @@map("users")
}

model Address {
  id        String @id @default(uuid())
  userId    String
  label     String
  address   String
  landmark  String?
  latitude  Float?
  longitude Float?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Plumber {
  id             String  @id @default(uuid())
  name           String
  initials       String
  phone          String  @unique
  email          String  @unique
  password       String
  rating         Float   @default(0)
  jobsCompleted  Int     @default(0)
  location       String
  isAvailable    Boolean @default(true)
  isVerified     Boolean @default(true)

  bookings Booking[]

  @@map("plumbers")
}

model Booking {
  id            String        @id @default(uuid())
  requestId     String        @unique @default(uuid())
  title         String
  category      String
  description   String
  address       String
  landmark      String?
  isEmergency   Boolean       @default(false)
  status        BookingStatus @default(SUBMITTED)
  preferredTime DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId    String
  user      User       @relation(fields: [userId], references: [id])
  plumberId String?
  plumber   Plumber?   @relation(fields: [plumberId], references: [id])
  photos    Photo[]
  estimate  Estimate?
  invoice   Invoice?
  review    Review?
  notes     Note[]

  @@map("bookings")
}

model Photo {
  id        String @id @default(uuid())
  bookingId String
  url       String
  type      PhotoType @default(BEFORE)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Estimate {
  id        String   @id @default(uuid())
  bookingId String   @unique
  labour    Int
  travel    Int
  parts     String   // JSON array of { name, cost }
  min       Int
  max       Int
  notes     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("estimates")
}

model Invoice {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  labour      Int
  travel      Int
  parts       String   // JSON array
  tax         Int
  total       Int
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Review {
  id        String  @id @default(uuid())
  bookingId String  @unique
  userId    String
  rating    Int
  comment   String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Note {
  id        String   @id @default(uuid())
  bookingId String
  content   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("notes")
}

enum Role {
  CUSTOMER
  OPERATIONS
  ADMIN
}

enum BookingStatus {
  SUBMITTED
  UNDER_REVIEW
  ESTIMATE_GENERATED
  ESTIMATE_ACCEPTED
  PLUMBER_ASSIGNED
  PLUMBER_EN_ROUTE
  ARRIVED
  WORK_STARTED
  COMPLETED
  PAYMENT_PENDING
  PAID
  CLOSED
  CANCELLED
}

enum PhotoType {
  BEFORE
  AFTER
  ISSUE
}
